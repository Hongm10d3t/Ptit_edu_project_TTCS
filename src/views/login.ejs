<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8">
    <title>Login</title>
</head>

<body>
    <h2>Đăng nhập</h2>

    <% if (error) { %>
        <p style="color:red;">
            <%= error %>
        </p>
        <% } %>

            <form action="/login" method="POST">
                <div>
                    <label>Username</label>
                    <input type="text" name="username" />
                </div>

                <div>
                    <label>Mật khẩu</label>
                    <input type="password" name="password" />
                </div>

                <button type="submit">Đăng nhập</button>
            </form>
</body>

</html>